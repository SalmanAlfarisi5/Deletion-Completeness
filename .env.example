# Copy to `.env` and fill in. `.env` is git-ignored; never commit real keys.

# ---- which memory backend -------------------------------------------------
# oss    = open-source Mem0 (`Memory`), runs locally, fully reproducible (recommended)
# hosted = Mem0 platform (`MemoryClient`), needs MEM0_API_KEY
MEM0_MODE=oss

# ---- which LLM provider drives extraction / judging / paraphrasing --------
# anthropic | openai
LLM_PROVIDER=anthropic

# ---- API keys (fill the ones your chosen mode/provider needs) -------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MEM0_API_KEY=

# ---- model overrides (optional; sensible defaults live in config.py) ------
# JUDGE_MODEL=claude-haiku-4-5-20251001
# JUDGE_MODEL=gpt-4o-mini

# ---- experiment knobs -----------------------------------------------------
USER_ID_PREFIX=u_alice
GLOBAL_SEED=42
