%  Database lineage: deletion / erasure under dependencies
% ---------------------------------------------------------------------
@article{p2e2,
  author  = {Chakraborty, Vishal and Kaminsky, Youri and Mehrotra, Sharad and
             Naumann, Felix and Nawab, Faisal and Pappachan, Primal and
             Sadoghi, Mohammad and Venkatasubramanian, Nalini},
  title   = {Meaningful Data Erasure in the Presence of Dependencies},
  journal = {Proceedings of the VLDB Endowment},
  volume  = {18},
  number  = {10},
  pages   = {3435--3448},
  year    = {2025},
  doi     = {10.14778/3748191.3748206},
  note    = {arXiv:2507.00343. Formalizes Pre-insertion Post-Erasure
             Equivalence (P2E2): erasing a cell must not enable any inference
             beyond what was already possible from the database state at
             that cell's insertion time---not an empty baseline; Opt-P2E2,
             the resulting minimal-cost dependency closure problem, is
             NP-hard.},
}

